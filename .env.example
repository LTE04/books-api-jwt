# ── Database ──────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=books_api
DB_USER=root
DB_PASS=

# ── JWT ───────────────────────────────────────────────────
# Generate a real secret:  php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=change-me-to-a-long-random-string-please-do-not-commit
JWT_TTL=3600
JWT_ISSUER=books-api
